{
  "info": {
    "name": "Customer Portal API - Mock Backend",
    "description": "Complete API collection for Customer Portal Mock Backend (No Database Required)",
    "version": "2.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001",
      "type": "string"
    },
    {
      "key": "apiUrl", 
      "value": "http://localhost:3001/api",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "customerEmail",
      "value": "customer@example.com",
      "type": "string"
    },
    {
      "key": "customerPassword",
      "value": "password123",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🏥 Health Check",
      "item": [
        {
          "name": "Backend Health Status",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Check if the mock backend server is running properly"
          },
          "response": []
        }
      ],
      "description": "Health check endpoints to verify server status"
    },
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Login - Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.to.have.status(200)) {",
                  "    const response = pm.response.json();",
                  "    if (response.success && response.data.token) {",
                  "        pm.collectionVariables.set('authToken', response.data.token);",
                  "        console.log('Customer token saved successfully');",
                  "        console.log('User:', response.data.user);",
                  "    }",
                  "}",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has success property', function () {",
                  "    pm.expect(pm.response.json()).to.have.property('success');",
                  "});",
                  "",
                  "pm.test('Response contains token', function () {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.success) {",
                  "        pm.expect(jsonData.data).to.have.property('token');",
                  "        pm.expect(jsonData.data).to.have.property('user');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\"\n}"
            },
            "url": {
              "raw": "{{apiUrl}}/auth/login",
              "host": ["{{apiUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login as customer (Sarah Johnson) - Mock user with portfolio data"
          },
          "response": []
        }
      ],
      "description": "Authentication endpoints for the mock backend"
    },
    {
      "name": "📊 Portfolio Management",
      "item": [
        {
          "name": "Get Portfolio Summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiUrl}}/portfolio/summary",
              "host": ["{{apiUrl}}"],
              "path": ["portfolio", "summary"]
            },
            "description": "Get portfolio overview including total value, performance, risk score"
          },
          "response": []
        },
        {
          "name": "Get Portfolio Holdings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiUrl}}/portfolio/holdings",
              "host": ["{{apiUrl}}"],
              "path": ["portfolio", "holdings"]
            },
            "description": "Get all current holdings (VOO, MSFT, AAPL, etc.)"
          },
          "response": []
        },
        {
          "name": "Get Transaction History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiUrl}}/portfolio/transactions",
              "host": ["{{apiUrl}}"],
              "path": ["portfolio", "transactions"]
            },
            "description": "Get transaction history with pagination support"
          },
          "response": []
        },
        {
          "name": "Get Transaction History - With Pagination",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiUrl}}/portfolio/transactions?limit=10&offset=0",
              "host": ["{{apiUrl}}"],
              "path": ["portfolio", "transactions"],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "Get paginated transaction history"
          },
          "response": []
        }
      ],
      "description": "Portfolio management endpoints with mock data"
    },
    {
      "name": "👤 User Management",
      "item": [
        {
          "name": "Get User Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiUrl}}/users/profile",
              "host": ["{{apiUrl}}"],
              "path": ["users", "profile"]
            },
            "description": "Get current user profile information"
          },
          "response": []
        },
        {
          "name": "Update User Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+1-555-9999\",\n  \"address\": \"456 Updated St, New York, NY 10001\"\n}"
            },
            "url": {
              "raw": "{{apiUrl}}/users/profile",
              "host": ["{{apiUrl}}"],
              "path": ["users", "profile"]
            },
            "description": "Update user profile information"
          },
          "response": []
        },
        {
          "name": "Get All Notifications",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiUrl}}/users/notifications",
              "host": ["{{apiUrl}}"],
              "path": ["users", "notifications"]
            },
            "description": "Get all user notifications"
          },
          "response": []
        },
        {
          "name": "Get Unread Notifications",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiUrl}}/users/notifications?unread=true",
              "host": ["{{apiUrl}}"],
              "path": ["users", "notifications"],
              "query": [
                {
                  "key": "unread",
                  "value": "true"
                }
              ]
            },
            "description": "Get only unread notifications"
          },
          "response": []
        }
      ],
      "description": "User profile and notification management"
    },
    {
      "name": "📈 Dashboard & Analytics",
      "item": [
        {
          "name": "Get Dashboard Metrics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiUrl}}/dashboard/metrics",
              "host": ["{{apiUrl}}"],
              "path": ["dashboard", "metrics"]
            },
            "description": "Get dashboard overview metrics including portfolio value, performance, holdings count"
          },
          "response": []
        },
        {
          "name": "Get Market Data",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiUrl}}/market/data",
              "host": ["{{apiUrl}}"],
              "path": ["market", "data"]
            },
            "description": "Get market indices and top movers data"
          },
          "response": []
        }
      ],
      "description": "Dashboard and market analytics endpoints"
    },
    {
      "name": "🧪 Testing & Examples",
      "item": [
        {
          "name": "Test Invalid Endpoint",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiUrl}}/invalid/endpoint",
              "host": ["{{apiUrl}}"],
              "path": ["invalid", "endpoint"]
            },
            "description": "Test 404 response for invalid endpoints"
          },
          "response": []
        },
        {
          "name": "Test Unauthorized Request",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiUrl}}/portfolio/summary",
              "host": ["{{apiUrl}}"],
              "path": ["portfolio", "summary"]
            },
            "description": "Test request without authentication token"
          },
          "response": []
        }
      ],
      "description": "Testing scenarios and error handling examples"
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Add timestamp to requests",
          "pm.request.headers.add({",
          "    key: 'X-Request-Time',",
          "    value: new Date().toISOString()",
          "});"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Global test for response time",
          "pm.test('Response time is less than 2000ms', function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(2000);",
          "});",
          "",
          "// Global test for content type",
          "pm.test('Response content-type is JSON', function () {",
          "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
          "});"
        ]
      }
    }
  ]
}