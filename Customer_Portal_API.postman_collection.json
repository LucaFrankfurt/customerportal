        },
        {
          "name": "Update User Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Updated First\",\n  \"lastName\": \"Updated Last\",\n  \"phone\": \"+1-555-2222\",\n  \"address\": \"123 Updated St, New York, NY 10001\",\n  \"riskTolerance\": \"Aggressive\",\n  \"investmentGoals\": \"Growth and Income\",\n  \"communicationPreference\": \"Email\"\n}"
