              "path": ["conversations", "1"]
            },
            "description": "Get conversation details and participants"
          }
        },
        {
          "name": "Get Conversation Messages",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/conversations/1/messages?limit=50&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["conversations", "1", "messages"],
