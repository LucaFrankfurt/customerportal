{
  "info": {
    "name": "Customer Portal API",
    "description": "Complete API collection for Customer Asset Management Portal",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001/api",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "employeeToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "customerToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Login - Employee",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.to.have.status(200)) {",
                  "    const response = pm.response.json();",
                  "    if (response.success && response.data.token) {",
                  "        pm.collectionVariables.set('employeeToken', response.data.token);",
                  "        pm.collectionVariables.set('authToken', response.data.token);",
                  "        console.log('Employee token saved successfully');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login as employee (Alex Thompson) - gets token for employee-only endpoints"
          }
        },
        {
          "name": "Login - Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.to.have.status(200)) {",
                  "    const response = pm.response.json();",
                  "    if (response.success && response.data.token) {",
                  "        pm.collectionVariables.set('customerToken', response.data.token);",
                  "        pm.collectionVariables.set('authToken', response.data.token);",
                  "        console.log('Customer token saved successfully');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login as customer (Sarah Johnson) - gets token for customer endpoints"
          }
        },
        {
          "name": "Login - Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.to.have.status(200)) {",
                  "    const response = pm.response.json();",
                  "    if (response.success && response.data.token) {",
                  "        pm.collectionVariables.set('adminToken', response.data.token);",
                  "        pm.collectionVariables.set('authToken', response.data.token);",
                  "        console.log('Admin token saved successfully');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login as admin (John Smith) - gets token with full access"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            },
            "description": "Logout current user"
          }
        }
      ],
      "description": "Authentication endpoints for login/logout"
    },
    {
      "name": "👥 Client Management (Employee Only)",
      "item": [
        {
          "name": "Get All Clients",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/clients?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["clients"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "search",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "status",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "priority",
                  "value": "",
                  "disabled": true
                }
              ]
            },
            "description": "Get paginated list of clients with optional search and filtering"
          }
        },
        {
          "name": "Search Clients",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/clients?search=pension&status=Active&priority=High",
              "host": ["{{baseUrl}}"],
              "path": ["clients"],
              "query": [
                {
                  "key": "search",
                  "value": "pension"
                },
                {
                  "key": "status",
                  "value": "Active"
                },
                {
                  "key": "priority",
                  "value": "High"
                }
              ]
            },
            "description": "Search clients by name, contact person, or email"
          }
        },
        {
          "name": "Get Client Statistics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/clients/stats",
              "host": ["{{baseUrl}}"],
              "path": ["clients", "stats"]
            },
            "description": "Get dashboard statistics for employee dashboard"
          }
        },
        {
          "name": "Get Client by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/clients/1",
              "host": ["{{baseUrl}}"],
              "path": ["clients", "1"]
            },
            "description": "Get specific client details"
          }
        },
        {
          "name": "Create New Client",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Investment Fund\",\n  \"contact_person\": \"Jane Smith\",\n  \"email\": \"jane.smith@newinvestment.com\",\n  \"phone\": \"+1-555-9999\",\n  \"aum\": \"$100M\",\n  \"status\": \"Onboarding\",\n  \"priority\": \"Medium\",\n  \"performance\": \"N/A\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/clients",
              "host": ["{{baseUrl}}"],
              "path": ["clients"]
            },
            "description": "Create a new client record"
          }
        },
        {
          "name": "Update Client",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Client Name\",\n  \"contact_person\": \"Updated Contact\",\n  \"email\": \"updated@example.com\",\n  \"phone\": \"+1-555-1111\",\n  \"aum\": \"$500M\",\n  \"status\": \"Active\",\n  \"priority\": \"High\",\n  \"performance\": \"+15.5%\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/clients/1",
              "host": ["{{baseUrl}}"],
              "path": ["clients", "1"]
            },
            "description": "Update existing client information"
          }
        }
      ],
      "description": "Client management endpoints (requires employee or admin role)",
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{employeeToken}}",
            "type": "string"
          }
        ]
      }
    },
    {
      "name": "📊 Portfolio Management (Customer)",
      "item": [
        {
          "name": "Get Portfolio Summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/portfolio/summary",
              "host": ["{{baseUrl}}"],
              "path": ["portfolio", "summary"]
            },
            "description": "Get customer portfolio summary statistics"
          }
        },
        {
          "name": "Get Portfolio Holdings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/portfolio/holdings",
              "host": ["{{baseUrl}}"],
              "path": ["portfolio", "holdings"]
            },
            "description": "Get current portfolio holdings and allocations"
          }
        },
        {
          "name": "Get Transaction History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/portfolio/transactions?limit=20&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["portfolio", "transactions"],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "Get paginated transaction history"
          }
        },
        {
          "name": "Get Performance History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/portfolio/performance?period=1Y",
              "host": ["{{baseUrl}}"],
              "path": ["portfolio", "performance"],
              "query": [
                {
                  "key": "period",
                  "value": "1Y",
                  "description": "1M, 3M, 6M, 1Y, 2Y, 5Y"
                }
              ]
            },
            "description": "Get historical performance data for charts"
          }
        }
      ],
      "description": "Portfolio management endpoints (requires customer role)",
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{customerToken}}",
            "type": "string"
          }
        ]
      }
    },
    {
      "name": "👤 User Profile Management",
