{
  "name": "customer-portal-monorepo",
  "version": "1.0.0",
  "description": "Customer Asset Management Portal - Full Stack Application",
  "private": true,
  "scripts": {
    "install:all": "npm install && npm run install:frontend && npm run install:backend",
    "install:frontend": "cd frontend && npm ci",
    "install:backend": "cd backend && npm ci",
    "dev": "concurrently --kill-others-on-fail \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:safe": "echo 'Starting backend...' && npm run dev:backend",
    "build": "npm run build:backend && npm run build:frontend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:frontend": "cd frontend && npm run preview",
    "start:backend": "cd backend && npm start",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:backend": "cd backend && npm run lint",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "cd frontend && npm run test",
    "test:backend": "cd backend && npm run test",
    "clean:all": "rm -rf node_modules frontend/node_modules backend/node_modules",
    "clean:frontend": "cd frontend && rm -rf node_modules dist",
    "clean:backend": "cd backend && rm -rf node_modules dist",
    "diagnostic": "chmod +x diagnostic.sh && ./diagnostic.sh",
    "db:docker:start": "docker-compose up -d postgres",
    "db:docker:stop": "docker-compose down",
    "db:docker:setup": "chmod +x backend/database/docker-setup.sh && ./backend/database/docker-setup.sh",
    "db:docker:reset": "docker-compose down -v && npm run db:docker:setup",
    "db:docker:logs": "docker-compose logs postgres",
    "db:admin": "echo 'Opening Adminer at http://localhost:8080' && open http://localhost:8080",
    "postinstall": "echo 'Root dependencies installed. Run npm run install:all for full setup.'",
    "fresh-install": "npm run clean:all && npm install && npm run install:all"
  },
  "keywords": [
    "customer-portal",
    "asset-management",
    "react",
    "nodejs",
    "typescript",
    "monorepo"
  ],
  "author": "Asset Capital Management",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}